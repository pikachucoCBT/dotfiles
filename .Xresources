!
! Ayu Mirage
!

! Font rendering

Xft.dpi:                  96
Xft.antialias:            true
Xft.hinting:              true
Xft.rgba:                 none
Xft.autohint:             false
Xft.hintstyle:            hintfull
Xft.lcdfilter:            lcddefault

! Options

urxvt.perl-ext-common:    default,matcher,url-select,keyboard-select,font-size
urxvt.keysym.M-u:         perl:url-select:select_next
urxvt.url-select.launcher:/usr/bin/firefox
urxvt.url-select.underline:true
URxvt.keysym.M-Escape:    perl:keyboard-select:activate
URxvt.keysym.M-s: perl:keyboard-select:search
URxvt.keyboard-select.clipboard:true 
urxvt.url-launcher:       /usr/bin/firefox
URxvt.keysym.C-h:     perl:font-size:increase
URxvt.keysym.C-j:   perl:font-size:decrease
urxvt.matcher.button:     1
urxvt.matcher.pattern.1:  \\bwww\\.[\\w-]+\\.[\\w./?&@#-]*[\\w/-]
URxvt.iso14755: false 
URxvt.iso14755_52: false

! Appearance

urxvt*font:             xft:Mono:size=10
urxvt*termName:         rxvt
urxvt*scrollBar:        false
urxvt*depth:            32
urxvt*lineSpace:	      1
urxvt*internalBorder:   16

! Special

*.foreground:   #bfbab0
*.background:   [95]#1f2430
*.cursorColor:  #ffcc66

! Black

*.color0:       #1f2430
*.color8:       #292b30

! Red

*.color1:       #ff3333
*.color9:       #ff6666

! Green

*.color2:       #bae67e
*.color10:      #cee6ac

! Yellow

*.color3:       #ffd580
*.color11:      #ffe6b3

! Blue

*.color4:       #73d0ff
*.color12:      #a6e1ff

! Magenta

*.color5:       #f28779
*.color13:      #ffd6da

! Cyan

*.color6:       #95e6cb
*.color14:      #ffffff

! White

*.color7:       #ffffff
*.color15:      #ffffff


! Bold, Italic, Underline

*.colorBD:     #e6e1cf
!*.colorIT:
!*.colorUL:

! Prompt in the middle bug workaround
URxvt.geometry: 400x400
